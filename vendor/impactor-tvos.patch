diff --git a/crates/plume_core/src/developer/mod.rs b/crates/plume_core/src/developer/mod.rs
index b68d1d9..e643f41 100644
--- a/crates/plume_core/src/developer/mod.rs
+++ b/crates/plume_core/src/developer/mod.rs
@@ -4,10 +4,20 @@ pub mod v1;
 
 pub use session::{DeveloperSession, RequestType};
 
+#[doc(hidden)]
+pub fn _build_endpoint(path: impl AsRef<str>) -> String {
+    // URL rewriting kept as a no-op hook for future experimentation; the
+    // /tvos/ endpoints for free-tier accounts appear to be unpopulated, so
+    // for now all requests stay at the documented /ios/ paths. tvOS
+    // behavior is toggled via a body parameter in qh_get_profile instead.
+    let path = path.as_ref();
+    format!("https://developerservices2.apple.com/services{path}")
+}
+
 #[macro_export]
 macro_rules! developer_endpoint {
     ($endpoint:expr) => {
-        format!("https://developerservices2.apple.com/services{}", $endpoint)
+        $crate::developer::_build_endpoint($endpoint)
     };
 }
 
